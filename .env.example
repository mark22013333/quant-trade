# Core database
DATABASE_URL=sqlite:///data/quant_trade.db

# FinMind (Taiwan market data)
# Fill this after you create your own API key.
FINMIND_API_KEY=
FINMIND_API_URL=https://api.finmindtrade.com/api/v4/data
FINMIND_USER_INFO_URL=https://api.web.finmindtrade.com/v2/user_info

# Shioaji (Sinopac)
SHIOAJI_APIKEY=
SHIOAJI_SECRET=
SHIOAJI_CA_PATH=
SHIOAJI_CA_PASSWORD=
SHIOAJI_CA_PERSON_ID=
# 僅在永豐模擬帳戶不提供 account_balance 時使用。
SHIOAJI_SIMULATION_CASH_FALLBACK=1000000

# TradingAdvisor / 選配 OpenAI transport
# 第一階段預設保持 Codex advisor 關閉，使用 stub advisor。
CODEX_ADVISOR_ENABLED=
OPENAI_API_KEY=
OPENAI_ADVISOR_MODEL=
OPENAI_ADVISOR_TIMEOUT_SEC=30

# Optional notifications (Phase 2)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
LINE_NOTIFY_TOKEN=
